# ─── OS / IDE ────────────────────────────────────────────────────────────────
.DS_Store
*.iml
.idea/
.vscode/
.fvm/

# ─── Claude / tool state ────────────────────────────────────────────────────
.claude/

# ─── Pipeline debug output (regenerated from tool/main_pipeline_dump.dart) ──
/test_output/

# ─── Flutter / Dart (app/) ──────────────────────────────────────────────────
/app/.dart_tool/
/app/.flutter-plugins
/app/.flutter-plugins-dependencies
/app/.packages
/app/.metadata
/app/build/
/app/coverage/
/app/pubspec_overrides.yaml

# ─── Android ────────────────────────────────────────────────────────────────
/app/android/.gradle/
/app/android/captures/
/app/android/local.properties
/app/android/**/gradle-wrapper.jar
/app/android/.idea/
/app/android/app/release/
/app/android/app/debug/
/app/android/app/profile/

# ─── iOS ────────────────────────────────────────────────────────────────────
/app/ios/Pods/
/app/ios/.symlinks/
/app/ios/Flutter/Flutter.framework/
/app/ios/Flutter/Flutter.podspec
/app/ios/Flutter/ephemeral/
/app/ios/Flutter/Generated.xcconfig
/app/ios/Flutter/flutter_export_environment.sh
/app/ios/Flutter/App.framework/
/app/ios/.last_build_id
/app/ios/Runner.xcworkspace/xcuserdata/
/app/ios/Runner.xcodeproj/xcuserdata/
/app/ios/Runner.xcodeproj/project.xcworkspace/xcuserdata/

# ─── macOS / Linux / Windows targets (not used; ignore generated bits) ──────
/app/macos/Pods/
/app/macos/Flutter/ephemeral/
/app/linux/flutter/ephemeral/
/app/windows/flutter/ephemeral/

# ─── Secrets / signing ──────────────────────────────────────────────────────
*.keystore
*.jks
key.properties
GoogleService-Info.plist
google-services.json
/app/android/app/upload-keystore.jks
